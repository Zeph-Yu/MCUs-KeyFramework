# Keil/ARM build outputs
Demos/STM32_StdPeriph_Demo/Objects/
Demos/STM32_StdPeriph_Demo/Listings/

# TI_MSPM0G3507_Demo: only track the specified files/folders
Demos/TI_MSPM0G3507_Demo/*
!Demos/TI_MSPM0G3507_Demo/Hardware/
!Demos/TI_MSPM0G3507_Demo/Hardware/**
!Demos/TI_MSPM0G3507_Demo/KeyDriver.c
!Demos/TI_MSPM0G3507_Demo/KeyDriver.syscfg

# Binary / firmware
*.axf

# Intermediate and compiler-generated files
*.lnp
*.crf
*.d
*.o
*.obj
*.map

# Linker / scatter scripts (generated)
*.sct

# Listings, logs and reports
*.lst
*.htm
*build_log.htm

# Backup and temporary files
*.Bak
*.bak
*~
*.swp

# IDE / user-specific files (ignore by default)
*.uvoptx
*.uvguix*

# Editor settings
.vscode/
*.code-workspace
